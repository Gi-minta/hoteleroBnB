# Usar una ruta absoluta evita ambigüedades de resolución entre distintas
# herramientas (prisma CLI, tsx, vitest) que a veces resuelven rutas
# relativas de forma inconsistente (relativas a prisma/schema.prisma vs. cwd).
DATABASE_URL="file:C:/ruta/absoluta/al/proyecto/data/hotelero.db"
JWT_SECRET="change-me"
PORT=3001

# Google Calendar (cuenta de servicio del hostal) — opcional.
# La sincronización queda deshabilitada hasta que las tres estén presentes
# y "googleSyncEnabled" esté en "true" en la tabla Configuracion (ver Ajustes).
GOOGLE_CALENDAR_CLIENT_EMAIL=""
GOOGLE_CALENDAR_PRIVATE_KEY=""
GOOGLE_CALENDAR_ID=""
